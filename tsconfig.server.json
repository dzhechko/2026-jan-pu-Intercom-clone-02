{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@conversation/*": ["./src/conversation/*"],
      "@pql/*": ["./src/pql/*"],
      "@revenue/*": ["./src/revenue/*"],
      "@integration/*": ["./src/integration/*"],
      "@iam/*": ["./src/iam/*"],
      "@notifications/*": ["./src/notifications/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "app", "widget", "**/*.test.ts", "**/*.spec.ts"]
}
